{
  "manifest_version": 3,
  "name": "Garimpei - Mercado Livre",
  "version": "1.1",
  "description": "Coleta automática de cookies do afiliado Mercado Livre",
  "permissions": ["cookies", "activeTab", "tabs", "clipboardWrite"],
  "host_permissions": ["https://*.mercadolivre.com.br/*"],
  "icons": {
    "16": "16.png",
    "32": "32.png",
    "48": "48.png",
    "128": "128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "16.png",
      "32": "32.png"
    }
  }
}
