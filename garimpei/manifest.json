{
  "manifest_version": 3,
  "name": "ML Cookie Helper",
  "version": "1.0",
  "description": "Extrai cookies essenciais do Mercado Livre",
  "permissions": [
    "cookies",
    "activeTab",
    "clipboardWrite"
  ],
  "host_permissions": [
    "https://*.mercadolivre.com.br/*"
  ],
  "action": {
    "default_popup": "popup.html"
  }
}